{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "type": "stat",
      "title": "Uptime",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "hjem_uptime_seconds",
          "legendFormat": "Uptime"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Total Lookups",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "hjem_lookups_total",
          "legendFormat": "Lookups"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Cache Hit Rate",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          },
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "hjem_cache_hits_total / (hjem_cache_hits_total + hjem_cache_misses_total)",
          "legendFormat": "Hit Rate"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Boliga Error Rate",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.1 }
            ]
          },
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "hjem_boliga_requests_total{result=\"fail\"} / (hjem_boliga_requests_total{result=\"ok\"} + hjem_boliga_requests_total{result=\"fail\"})",
          "legendFormat": "Error Rate"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Boliga OK",
      "gridPos": { "h": 4, "w": 2, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "hjem_boliga_requests_total{result=\"ok\"}",
          "legendFormat": "OK"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Boliga Fail",
      "gridPos": { "h": 4, "w": 2, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "hjem_boliga_requests_total{result=\"fail\"}",
          "legendFormat": "Fail"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Cache Hits",
      "gridPos": { "h": 4, "w": 3, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "hjem_cache_hits_total",
          "legendFormat": "Hits"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Lookups per Minute",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50,
            "lineWidth": 1,
            "barAlignment": 0
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(hjem_lookups_total[5m]) * 60",
          "legendFormat": "Lookups/min"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Boliga API Requests",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "OK/min" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Fail/min" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "rate(hjem_boliga_requests_total{result=\"ok\"}[5m]) * 60",
          "legendFormat": "OK/min"
        },
        {
          "expr": "rate(hjem_boliga_requests_total{result=\"fail\"}[5m]) * 60",
          "legendFormat": "Fail/min"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Cache Performance",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Hits/min" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Misses/min" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "rate(hjem_cache_hits_total[5m]) * 60",
          "legendFormat": "Hits/min"
        },
        {
          "expr": "rate(hjem_cache_misses_total[5m]) * 60",
          "legendFormat": "Misses/min"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Cache Hit Rate Over Time",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(hjem_cache_hits_total[5m]) / (rate(hjem_cache_hits_total[5m]) + rate(hjem_cache_misses_total[5m]))",
          "legendFormat": "Hit Rate"
        }
      ]
    },
    {
      "type": "table",
      "title": "Recent Errors",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "targets": [
        {
          "expr": "hjem_recent_errors",
          "legendFormat": "{{type}}",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": false, "__name__": true, "instance": true, "job": true },
            "renameByName": { "type": "Error Type", "Value": "Count" }
          }
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["hjem", "boliga"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus"
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Hjem - Boligpris Analyse",
  "uid": "hjem-dashboard",
  "version": 1
}
